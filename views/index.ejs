    <!-- ── EDUCATION ─────────────────────────────────────────────────── -->
    <section id="education" class="py-24 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-white mb-12 text-center">Education</h2>
