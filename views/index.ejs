    <!-- ── PROJECTS ──────────────────────────────────────────────────── -->
    <section id="projects" class="py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-white mb-4 text-center">Work Samples</h2>
        <p class="text-center text-gray-500 text-sm mb-12">A selection of projects built end-to-end</p>

        <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-8">

          <!-- ── Project 1: WaitWell ── -->
          <div class="flex flex-col bg-gray-900 border border-gray-800 rounded-2xl p-8 hover:border-[#02066F] transition-colors group">
            <div class="flex items-start justify-between gap-3 mb-3">
              <h3 class="text-xl font-bold text-white leading-snug">WaitWell</h3>
              <span class="shrink-0 text-xs bg-[#02066F]/30 text-[#6B72FF] border border-[#02066F] px-2.5 py-1 rounded-full">SaaS</span>
            </div>
            <p class="text-[#6B72FF] text-sm font-medium mb-3">Patient Communication &amp; Queue Management Platform</p>
            <p class="text-gray-400 text-sm leading-relaxed mb-4 flex-1">
              Real-time hospital visit progress tracker that keeps patients informed at every step of their care journey — reducing anxiety through live queue updates, an AI health assistant, Stripe-gated tiers, and push notifications.
            </p>
            <!-- Outcome badges -->
            <ul class="text-gray-400 text-xs space-y-1 mb-5">
              <li class="flex items-center gap-2"><span class="text-[#6B72FF]">✓</span> Multi-role auth (patient, admin) with RBAC</li>
              <li class="flex items-center gap-2"><span class="text-[#6B72FF]">✓</span> AI health chat with per-user rate limiting</li>
              <li class="flex items-center gap-2"><span class="text-[#6B72FF]">✓</span> CI/CD via GitHub Actions, full unit test coverage</li>
            </ul>
            <div class="flex flex-wrap gap-2 mb-5">
              <% ["Next.js 16","TypeScript","Tailwind v4","Supabase","Stripe","OpenRouter AI","Vercel AI SDK","Web Push","Vitest"].forEach(t => { %>
                <span class="bg-[#02066F]/30 text-[#8B8FFF] text-xs px-2.5 py-1 rounded-full border border-[#02066F]"><%= t %></span>
              <% }) %>
            </div>
            <div class="flex flex-wrap gap-3 mt-auto">
              <a href="#" class="text-xs font-semibold text-white bg-[#02066F] hover:bg-[#0309A8] px-4 py-2 rounded-lg transition-colors">Live Demo</a>
              <a href="https://github.com/NSCC-ITC-Winter2026-WEBD3031-700-MCa/project-waitwell" target="_blank" rel="noopener noreferrer" class="text-xs font-semibold text-gray-400 hover:text-white border border-gray-700 hover:border-[#02066F] px-4 py-2 rounded-lg transition-colors">GitHub</a>
              <a href="/projects/waitwell" class="text-xs font-semibold text-[#6B72FF] hover:text-white border border-[#02066F] hover:border-[#6B72FF] px-4 py-2 rounded-lg transition-colors">Learn More →</a>
            </div>
          </div>

          <!-- ── Project 2: Himalaya Hearth ── -->
          <div class="flex flex-col bg-gray-900 border border-gray-800 rounded-2xl p-8 hover:border-[#02066F] transition-colors group">
            <div class="flex items-start justify-between gap-3 mb-3">
              <h3 class="text-xl font-bold text-white leading-snug">Himalaya Hearth</h3>
              <span class="shrink-0 text-xs bg-[#02066F]/30 text-[#6B72FF] border border-[#02066F] px-2.5 py-1 rounded-full">WordPress</span>
            </div>
            <p class="text-[#6B72FF] text-sm font-medium mb-3">Custom WordPress Travel Site</p>
            <p class="text-gray-400 text-sm leading-relaxed mb-4 flex-1">
              A Nepal-focused travel brand needed a CMS-driven site to showcase and sell curated tour packages — each with pricing, duration, location, and imagery — without relying on a page builder.
            </p>
            <ul class="text-gray-400 text-xs space-y-1 mb-5">
              <li class="flex items-center gap-2"><span class="text-[#6B72FF]">✓</span> Custom CPT with archive &amp; single-tour templates (PHP)</li>
              <li class="flex items-center gap-2"><span class="text-[#6B72FF]">✓</span> ACF metadata badges — price, duration, location</li>
              <li class="flex items-center gap-2"><span class="text-[#6B72FF]">✓</span> Dynamically queried "Related Tours" section</li>
            </ul>
            <div class="flex flex-wrap gap-2 mb-5">
              <% ["WordPress","PHP","GeneratePress","ACF","Tailwind CSS","Custom CSS","REST API"].forEach(t => { %>
                <span class="bg-[#02066F]/30 text-[#8B8FFF] text-xs px-2.5 py-1 rounded-full border border-[#02066F]"><%= t %></span>
              <% }) %>
            </div>
            <div class="flex flex-wrap gap-3 mt-auto">
              <a href="#" class="text-xs font-semibold text-white bg-[#02066F] hover:bg-[#0309A8] px-4 py-2 rounded-lg transition-colors">Live Demo</a>
              <a href="#" class="text-xs font-semibold text-gray-400 hover:text-white border border-gray-700 hover:border-[#02066F] px-4 py-2 rounded-lg transition-colors">GitHub</a>
              <a href="/projects/himalaya-hearth" class="text-xs font-semibold text-[#6B72FF] hover:text-white border border-[#02066F] hover:border-[#6B72FF] px-4 py-2 rounded-lg transition-colors">Learn More →</a>
            </div>
          </div>

          <!-- ── Project 3: Movie Reviews ── -->
          <div class="flex flex-col bg-gray-900 border border-gray-800 rounded-2xl p-8 hover:border-[#02066F] transition-colors group">
            <div class="flex items-start justify-between gap-3 mb-3">
              <h3 class="text-xl font-bold text-white leading-snug">Movie Reviews</h3>
              <span class="shrink-0 text-xs bg-[#02066F]/30 text-[#6B72FF] border border-[#02066F] px-2.5 py-1 rounded-full">ASP.NET Core</span>
            </div>
            <p class="text-[#6B72FF] text-sm font-medium mb-3">MVC Admin Application</p>
            <p class="text-gray-400 text-sm leading-relaxed mb-4 flex-1">
              Multi-role movie catalog and review platform where admins manage content and critics submit scored reviews — featuring a centralized dashboard, soft-delete, and Azure Blob image uploads.
            </p>
            <ul class="text-gray-400 text-xs space-y-1 mb-5">
              <li class="flex items-center gap-2"><span class="text-[#6B72FF]">✓</span> Role-based auth (Admin, Critic) with ASP.NET Identity</li>
              <li class="flex items-center gap-2"><span class="text-[#6B72FF]">✓</span> Admin dashboard with aggregate stats</li>
              <li class="flex items-center gap-2"><span class="text-[#6B72FF]">✓</span> EF Core + Dapper, Azure Blob Storage</li>
            </ul>
            <div class="flex flex-wrap gap-2 mb-5">
              <% ["ASP.NET Core MVC","C#","EF Core","Dapper","SQL Server","Azure Blob","Identity"].forEach(t => { %>
                <span class="bg-[#02066F]/30 text-[#8B8FFF] text-xs px-2.5 py-1 rounded-full border border-[#02066F]"><%= t %></span>
              <% }) %>
            </div>
            <div class="flex flex-wrap gap-3 mt-auto">
              <a href="#" class="text-xs font-semibold text-white bg-[#02066F] hover:bg-[#0309A8] px-4 py-2 rounded-lg transition-colors">Live Demo</a>
              <a href="#" class="text-xs font-semibold text-gray-400 hover:text-white border border-gray-700 hover:border-[#02066F] px-4 py-2 rounded-lg transition-colors">GitHub</a>
              <a href="/projects/movie-reviews" class="text-xs font-semibold text-[#6B72FF] hover:text-white border border-[#02066F] hover:border-[#6B72FF] px-4 py-2 rounded-lg transition-colors">Learn More →</a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── EXPERIENCE ────────────────────────────────────────────────── -->
