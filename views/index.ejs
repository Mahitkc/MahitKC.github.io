          </div>

          <!-- Job 2 -->
          <div class="relative">
            <span class="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-gray-800 border-2 border-gray-900 ring-2 ring-[#02066F]"></span>
            <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
