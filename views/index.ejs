              <li>Diagnosed and resolved hardware, network, and application issues to ensure business continuity.</li>
              <li>Implemented basic system security practices and documentation.</li>
            </ul>
            <div class="flex flex-wrap gap-2 mt-4">
              <% ["Windows","Linux","Networking","NTFS Permissions","VMware"].forEach(t => { %>
                <span class="bg-gray-800 text-gray-400 text-xs px-2.5 py-1 rounded-full"><%= t %></span>
              <% }) %>
            </div>
          </div>

        </div>
      </div>
