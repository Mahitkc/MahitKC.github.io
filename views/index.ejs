    <!-- ── SKILLS ────────────────────────────────────────────────────── -->
    <section id="skills" class="py-24 px-6 bg-gray-900">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-white mb-12 text-center">Skills</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

          <div class="bg-gray-800 rounded-2xl p-6 border border-gray-800">
            <h3 class="text-[#6B72FF] font-semibold mb-4 uppercase text-xs tracking-widest">Languages &amp; Frameworks</h3>
            <div class="flex flex-wrap gap-2">
              <% ["JavaScript","PHP","HTML","CSS","React","Vue","WordPress","SASS/SCSS"].forEach(s => { %>
                <span class="bg-gray-700 text-gray-200 text-xs px-3 py-1 rounded-full"><%= s %></span>
              <% }) %>
            </div>
          </div>

          <div class="bg-gray-800 rounded-2xl p-6 border border-gray-800">
            <h3 class="text-[#6B72FF] font-semibold mb-4 uppercase text-xs tracking-widest">Database</h3>
            <div class="flex flex-wrap gap-2">
              <% ["SQL / MySQL","CRUD","Schema Design","Performance Basics"].forEach(s => { %>
                <span class="bg-gray-700 text-gray-200 text-xs px-3 py-1 rounded-full"><%= s %></span>
              <% }) %>
            </div>
          </div>

          <div class="bg-gray-800 rounded-2xl p-6 border border-gray-800">
            <h3 class="text-[#6B72FF] font-semibold mb-4 uppercase text-xs tracking-widest">Web &amp; App</h3>
            <div class="flex flex-wrap gap-2">
              <% ["REST APIs","JSON","DOM Manipulation","Responsive Design","Accessibility","Secure Coding"].forEach(s => { %>
                <span class="bg-gray-700 text-gray-200 text-xs px-3 py-1 rounded-full"><%= s %></span>
              <% }) %>
            </div>
          </div>

          <div class="bg-gray-800 rounded-2xl p-6 border border-gray-800">
            <h3 class="text-[#6B72FF] font-semibold mb-4 uppercase text-xs tracking-widest">System &amp; Cloud</h3>
            <div class="flex flex-wrap gap-2">
              <% ["Linux","Windows Admin","VMware","AWS","Azure","Virtualization","NTFS Permissions"].forEach(s => { %>
                <span class="bg-gray-700 text-gray-200 text-xs px-3 py-1 rounded-full"><%= s %></span>
              <% }) %>
            </div>
          </div>

          <div class="bg-gray-800 rounded-2xl p-6 border border-gray-800">
            <h3 class="text-[#6B72FF] font-semibold mb-4 uppercase text-xs tracking-widest">Version Control</h3>
            <div class="flex flex-wrap gap-2">
              <% ["Git","GitHub","Branching","Pull Requests","Code Reviews"].forEach(s => { %>
                <span class="bg-gray-700 text-gray-200 text-xs px-3 py-1 rounded-full"><%= s %></span>
              <% }) %>
            </div>
          </div>

        </div>
      </div>
