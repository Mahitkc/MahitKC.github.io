            <div class="flex flex-wrap gap-2 mt-4">
              <% ["PHP","MySQL","REST/JSON","Linux","Git"].forEach(t => { %>
                <span class="bg-gray-800 text-gray-400 text-xs px-2.5 py-1 rounded-full"><%= t %></span>
              <% }) %>
