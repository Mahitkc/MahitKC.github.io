            </ul>
            <div class="flex flex-wrap gap-2 mt-4">
              <% ["React","JavaScript (ES6)","HTML","CSS3","Bootstrap","Tailwind","Git"].forEach(t => { %>
                <span class="bg-gray-800 text-gray-400 text-xs px-2.5 py-1 rounded-full"><%= t %></span>
              <% }) %>
            </div>
          </div>

          <!-- Job 3 -->
          <div class="relative">
            <span class="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-gray-800 border-2 border-gray-900 ring-2 ring-[#02066F]"></span>
            <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
              <div>
